<!-- templates/indexes/home_simple.html -->
{% extends 'base.html' %}
{% load static %}

{% block title %}嘉盛浸信會 - 首頁{% endblock %}

{% block content %}
<!-- 顶部欢迎横幅 -->
<section id="showcase">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-12">
                <img src="{% static 'img/lords_prayer.png' %}" alt="主禱文">
                <img src="{% static 'img/slogan.jpg' %}" alt="標語">
                <h1 class="display-4 mt-5">嘉盛浸信會</h1>
                <p class="lead">在每一代以生命見證，活出基督的樣式，轉化社區</p>
            </div>
        </div>
    </div>
</section>

<!-- 兩欄：事工動態和代禱事項 -->
<section id="services" class="py-5">
    <div class="container">
        <div class="row">
            <!-- 左欄：事工動態 -->
            <div class="col-md-6 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="fas fa-hands-helping me-2"></i>事工動態
                        </h4>
                    </div>
                    <div class="card-body">
                        {% if recent_ministries %}
                            <!-- 圖片輪播 -->
                            <div id="ministryCarousel" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner">
                                    {% for ministry in recent_ministries %}
                                    <div class="carousel-item {% if forloop.first %}active{% endif %}">
                                        {% if ministry.image %}
                                        <div class="mb-3 text-center">
                                            <img src="{{ ministry.image.url }}" 
                                                 alt="{{ ministry.title }}"
                                                 class="img-fluid rounded" 
                                                 style="max-height: 200px; object-fit: cover;">
                                        </div>
                                        {% endif %}
                                        <h6 class="text-primary">
                                            {{ ministry.activity_date|date:"Y年m月d日" }}
                                            {% if ministry.location %}
                                            <small class="text-muted">
                                                <i class="fas fa-map-marker-alt ms-2"></i>
                                                {{ ministry.location }}
                                            </small>
                                            {% endif %}
                                        </h6>
                                        <h5 class="card-title">{{ ministry.title }}</h5>
                                        {% if ministry.description %}
                                        <p class="card-text">{{ ministry.description|truncatechars:100 }}</p>
                                        {% endif %}
                                    </div>
                                    {% endfor %}
                                </div>
                                
                                {% if recent_ministries|length > 1 %}
                                <button class="carousel-control-prev" type="button" 
                                        data-bs-target="#ministryCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button"
                                        data-bs-target="#ministryCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                                {% endif %}
                            </div>
                        {% else %}
                            <p class="text-muted text-center py-4">暫無事工動態</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- 右欄：代禱事項 -->
            <div class="col-md-6 mb-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="fas fa-pray me-2"></i>代禱事項
                        </h4>
                    </div>
                    <div class="card-body">
                        {% if recent_prayers %}
                            <div class="prayer-list">
                                {% for prayer in recent_prayers %}
                                <div class="prayer-item mb-3 pb-3 {% if not forloop.last %}border-bottom{% endif %}">
                                    {% if prayer.is_urgent %}
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h5 class="text-danger">
                                            <span class="badge bg-danger me-2">緊急</span>
                                            {{ prayer.title }}
                                        </h5>
                                    </div>
                                    {% else %}
                                    <h5 class="text-primary">{{ prayer.title }}</h5>
                                    {% endif %}
                                    
                                    <div class="prayer-content mt-2">
                                        <p>{{ prayer.content|truncatechars:150 }}</p>
                                    </div>
                                    
                                    <div class="d-flex justify-content-between mt-2">
                                        <small class="text-muted">
                                            <i class="far fa-calendar me-1"></i>
                                            {{ prayer.display_date|date:"m月d日" }}
                                        </small>
                                    </div>
                                </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <p class="text-muted text-center py-4">暫無代禱事項</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}